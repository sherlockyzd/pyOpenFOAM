FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    // p
    // {
    //     solver          PETSc;          // 使用PETSc求解器
    //     petsc_solver    cg;          // GMRES Krylov方法 (gmres, cg, bicgstab)  
    //     preconditioner  ilu;            // ILU预处理器(GPU兼容，稳定可靠)
    //     use_gpu         false;           // 启用GPU加速矩阵和向量
    //     tolerance       1e-6;
    //     relTol          0.01;
    //     maxIter         1000;
    // }

    // U
    // {
    //     solver          PETSc;
    //     petsc_solver    bicgstab;       // BiCGSTAB对非对称矩阵效果好
    //     preconditioner  ilu;            // ILU预处理器
    //     tolerance       1e-6;
    //     relTol          0.1;
    //     maxIter         1000;
    // }
    p
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-06;
        relTol          0;
        maxIter         1000;
    }

    U
    {
        solver          smoothSolver;
        smoother        DILU;
        tolerance       1e-05;
        relTol          0;
        maxIter         100;
    }

    // T
    // {
    //     solver          smoothSolver;
    //     smoother        DILU;
    //     tolerance       1e-05;
    //     relTol          0;
    //     maxIter         100;
    // }
}

SIMPLE
{
    nCorrectors     1;
    residualControl
    {
        p               0.0001;
        U               0.0001;
        T               0.0001;
    }
}

PISO
{
    nCorrectors     2;
    nNonOrthogonalCorrectors 0;
    // pRefCell        0;
    // pRefValue       0;
}

relaxationFactors
{
    fields
    {
        p               0.3;
    } 
    equations 
    { 
        U               0.7; 
        T               0.9; 
    } 
} 


